{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["nb_joueurs", "joueurs", "scores"],
  "additionalProperties": false,
  "properties": {
    "nb_joueurs": {
      "type": "integer",
      "minimum": 2,
      "maximum": 4
    },
    "joueurs": {
      "type": "array",
      "minItems": 2,
      "maxItems": 4,
      "items": {
        "type": "object",
        "required": ["joueur", "id", "prenom", "nom"],
        "additionalProperties": false,
        "properties": {
          "joueur": { "type": "integer", "minimum": 1 },
          "id":     { "type": "integer", "minimum": 1 },
          "prenom": { "type": "string", "minLength": 1 },
          "nom":    { "type": "string", "minLength": 1 }
        }
      }
    },
    "scores": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["saison", "type", "joueurs"],
        "additionalProperties": false,
        "properties": {
          "saison": {
            "type": "string",
            "enum": ["Saison 1", "Saison 2", "Saison 3"]
          },
          "type": {
            "type": "string",
            "enum": ["eau", "herbe", "pierre", "sakura"]
          },
          "joueurs": {
            "type": "object",
            "minProperties": 2,
            "maxProperties": 4,
            "patternProperties": {
              "^joueur[1-4]$": {
                "type": "integer",
                "minimum": 0
              }
            },
            "additionalProperties": false
          }
        }
      }
    }
  }
}